# ── 开发阶段（必填其一）────────────────────────────────────────────────────
# 开发：设置 FALSE + GOOGLE_API_KEY（无需 GCP 凭证）
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_API_KEY=your_google_api_key_here

# ── 生产阶段（GOOGLE_GENAI_USE_VERTEXAI=TRUE 时必填）───────────────────────
GOOGLE_GENAI_USE_VERTEXAI=TRUE
VERTEX_AI_PROJECT_ID=your_gcp_project_id
VERTEX_AI_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=./credentials/service-account.json

# ── Firebase / Firestore ──────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your_firebase_project_id

# ── Vertex AI Vector Search ───────────────────────────────────────────────
VECTOR_SEARCH_INDEX_ID=your_vector_search_index_id
VECTOR_SEARCH_ENDPOINT_ID=your_vector_search_endpoint_id
